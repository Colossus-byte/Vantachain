rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - username: string (required)
    //   - onboarded: boolean (required)
    //   - tokenBalance: number
    //   - currentTopicId: string
    //   - currentSubtopicIndex: number
    //   - avatarUrl: string
    //   - bio: string
    //   - did: string
    //   - walletAddress: string
    //   - isPro: boolean
    //   - isPrivate: boolean
    //   - aiSentinelAccess: boolean
    //   - vantaRank: number
    //   - language: string
    //   - guild: string
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAny(['username', 'onboarded']) &&
             (data.username is string && data.username.size() <= 100) &&
             (data.onboarded is bool) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 500)) &&
             (!('did' in data) || (data.did is string && data.did.size() <= 100)) &&
             (!('walletAddress' in data) || (data.walletAddress is string && data.walletAddress.size() <= 100));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Users cannot delete their own profile directly for now

      // ── User credentials sub-collection ─────────────────────────────────────
      // Private to the owner. Credential IDs are known slugs (no arbitrary IDs).
      match /credentials/{credentialId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
                         request.resource.data.keys().hasAll(['id', 'earnedAt', 'verificationHash']) &&
                         request.resource.data.id is string &&
                         request.resource.data.id.size() <= 64 &&
                         request.resource.data.earnedAt is number &&
                         request.resource.data.verificationHash is string &&
                         request.resource.data.verificationHash.size() <= 128;
        allow update, delete: if false; // Credentials are immutable once earned
      }
    }

    // ── Public credentials ────────────────────────────────────────────────────
    // Doc ID: {walletAddress}_{credentialSlug}. Anyone can read; only owner can create.
    match /public_credentials/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasAll(['walletAddress', 'credentialName', 'earnedAt', 'verificationHash']) &&
                       request.resource.data.walletAddress is string &&
                       request.resource.data.walletAddress.size() <= 42 &&
                       request.resource.data.credentialName is string &&
                       request.resource.data.credentialName.size() <= 100 &&
                       request.resource.data.earnedAt is number &&
                       request.resource.data.verificationHash is string &&
                       request.resource.data.verificationHash.size() <= 128;
      allow update, delete: if false; // Immutable for integrity
    }

    // ── Waitlist ─────────────────────────────────────────────────────────────
    // Public create: anyone may add their email. No reads, updates, or deletes.
    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt']) &&
                       request.resource.data.email is string &&
                       request.resource.data.email.size() <= 254 &&
                       request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
      allow read, update, delete: if false;
    }

    // ── Activity Feed ─────────────────────────────────────────────────────────
    // Anyone can write lesson-completion events (anonymized). Public read for live feed.
    match /activity_feed/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['displayId', 'lessonTitle', 'topicTitle', 'timestamp']) &&
                       request.resource.data.displayId is string &&
                       request.resource.data.displayId.size() <= 50 &&
                       request.resource.data.lessonTitle is string &&
                       request.resource.data.lessonTitle.size() <= 200 &&
                       request.resource.data.topicTitle is string &&
                       request.resource.data.topicTitle.size() <= 200;
      allow read: if true;
      allow update, delete: if false;
    }

    // ── Leaderboard ───────────────────────────────────────────────────────────
    // Public read so GuildLeaderboard component can show top users.
    // Only the authenticated owner can write their own entry.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // ── Analytics Events ──────────────────────────────────────────────────────
    // Anyone can write analytics events (including anonymous users).
    // Only authenticated users (admin) can read.
    match /events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['eventName', 'walletAddress', 'timestamp']) &&
                       request.resource.data.eventName is string &&
                       request.resource.data.eventName.size() <= 100 &&
                       request.resource.data.walletAddress is string &&
                       request.resource.data.walletAddress.size() <= 100;
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    // ── Referral Events ───────────────────────────────────────────────────────
    // Created by referred user on first lesson. Claimed (updated) by referrer.
    match /referral_events/{eventId} {
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasAll(['referrerCode', 'referredUid', 'referrerRewarded', 'referredRewarded']) &&
                       request.resource.data.referrerCode is string &&
                       request.resource.data.referrerCode.size() <= 20 &&
                       request.resource.data.referredUid is string &&
                       request.resource.data.referredUid.size() <= 128 &&
                       request.resource.data.referrerRewarded == false &&
                       request.resource.data.referredRewarded == false;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['referrerRewarded', 'referredRewarded']);
      allow delete: if false;
    }

    // ── Wallet Registrations ──────────────────────────────────────────────────
    // Written once on first wallet connection. Public read for admin dashboard.
    // Doc ID = lowercase wallet address. Updates blocked (first-registration wins).
    match /wallet_registrations/{address} {
      allow create: if request.resource.data.keys().hasOnly(['address', 'connectedAt', 'username']) &&
                       request.resource.data.address is string &&
                       request.resource.data.address.size() <= 42 &&
                       request.resource.data.username is string &&
                       request.resource.data.username.size() <= 100;
      allow read: if true;
      allow update, delete: if false;
    }
  }
}
