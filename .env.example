# Claude API Key (primary AI — quiz generation, assistant, sentiment oracle)
# Get one at https://console.anthropic.com/
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API Key (news pulse, audio narration, video prompts)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# WalletConnect Project ID (WalletConnect QR modal)
# Get one at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Block Explorer API Keys (CrossChainPortfolio live data)
# Free tier keys are sufficient — register at each explorer
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here
VITE_BSCSCAN_API_KEY=your_bscscan_api_key_here
VITE_POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Google Sheets API (waitlist form submissions)
# Create a service account at https://console.cloud.google.com/
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-from-url
