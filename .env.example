# ── Firebase (required) ───────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
# Project: clarix-protocol
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=clarix-protocol.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=clarix-protocol
VITE_FIREBASE_STORAGE_BUCKET=clarix-protocol.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ── Claude API (required for AI features) ────────────────────────────────────
# Get one at https://console.anthropic.com/
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# ── Google Gemini (news pulse, audio narration) ───────────────────────────────
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get one at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Block Explorer API Keys (CrossChainPortfolio) ────────────────────────────
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here
VITE_BSCSCAN_API_KEY=your_bscscan_api_key_here
VITE_POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ── Google Sheets API (waitlist form) ─────────────────────────────────────────
GOOGLE_CLIENT_EMAIL=your-service-account@clarix-protocol.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-from-url

# ── Admin dashboard key ───────────────────────────────────────────────────────
VITE_ADMIN_KEY=your_admin_password_here
